{
  "$schema": "https://raw.githubusercontent.com/jetify-com/devbox/0.16.0/.schema/devbox.schema.json",
  "packages": [
    "nodejs@22",
    "pnpm@10.30.0",
    "gh@2.89.0",
    "pinact@3.8.0",
    "jq@1.8.1",
    "awscli2@2.33.2"
  ],
  "shell": {
    "init_hook": [
      "echo 'devbox ready' > /dev/null"
    ],
    "scripts": {
      "crawler-diagnose": "bash scripts/crawler-diagnose.sh",
      "crawler-logs": "bash scripts/check-crawler-logs.sh \"$@\""
    }
  }
}
