{
  "permissions": {
    "deny": [
      "Read(~/.aws/config)",
      "Read(//Users/zuoxiangtailang/.aws/config)",
      "Bash(cat ~/.aws/config)",
      "Bash(cat /Users/zuoxiangtailang/.aws/config)",
      "Bash(less ~/.aws/config)",
      "Bash(less /Users/zuoxiangtailang/.aws/config)",
      "Bash(more ~/.aws/config)",
      "Bash(more /Users/zuoxiangtailang/.aws/config)",
      "Bash(head ~/.aws/config)",
      "Bash(head /Users/zuoxiangtailang/.aws/config)",
      "Bash(tail ~/.aws/config)",
      "Bash(tail /Users/zuoxiangtailang/.aws/config)",
      "Bash(bat ~/.aws/config)",
      "Bash(bat /Users/zuoxiangtailang/.aws/config)"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/announce-env.sh\""
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Edit|Write|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/enforce-worktree.sh\""
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "EnterWorktree",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/sync-vscode-worktree.sh\""
          }
        ]
      }
    ]
  }
}
