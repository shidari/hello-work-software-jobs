# Apple container sandbox 用の認証情報。
# このファイルを `.env.sandbox` にコピーして値を埋める（.env.sandbox は .gitignore 対象）。

# --- GitHub CLI (`gh`) ---
# https://github.com/settings/tokens から発行。
# 推奨 scope: repo, read:org, workflow
GH_TOKEN=

# --- Cloudflare Workers (`wrangler`) ---
# https://dash.cloudflare.com/profile/api-tokens
# テンプレート: "Edit Cloudflare Workers"
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=

# --- Vercel (`vercel`) ---
# https://vercel.com/account/tokens
VERCEL_TOKEN=

# --- Claude Code (`claude`) ---
# どちらか片方でよい:
#   - OAuth Token: ホスト側で `claude setup-token` を実行して取得
#   - API Key: https://console.anthropic.com/ から発行
CLAUDE_CODE_OAUTH_TOKEN=
# ANTHROPIC_API_KEY=
