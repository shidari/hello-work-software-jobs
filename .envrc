#!/usr/bin/env bash
# direnv hook: when `cd` into the repo, ensure sho-sandbox container is up.
#
# Requires direnv (`brew install direnv`) and `direnv allow` once.
# Skips silently if `container` CLI isn't available (e.g. non-Mac host).

command -v container >/dev/null 2>&1 || return 0

# If image isn't loaded, instruct (don't auto-build — too slow on first run).
if ! container image ls 2>/dev/null | awk 'NR>1 && $1=="sho-sandbox" {f=1} END{exit !f}'; then
  echo "[sandbox] sho-sandbox image not loaded. Build & load:"
  echo "          ./scripts/sandbox-image.sh"
  return 0
fi

"$PWD/scripts/sandbox.sh" --ensure-up
