{
  "$schema": "https://unpkg.com/knip@6/schema.json",
  "ignore": ["**/dist/**", "**/.next/**", "**/generated/**"],
  "ignoreBinaries": [
    "tsdown",
    "tsx",
    "vitest",
    "cdk",
    "next",
    "storybook",
    "sqlite3",
    "kysely-codegen",
    "build",
    "infra/local/e2e.sh"
  ],
  "workspaces": {
    ".": {
      "entry": [".github/workflows/*.{yml,yaml}"],
      "ignoreDependencies": ["@anthropic-ai/claude-code", "vercel", "wrangler"]
    },
    "apps/backend/api": {
      "entry": [
        "src/index.ts",
        "test/**/*.{spec,test}.ts",
        "test/d1/apply-migrations.ts",
        "test/mock.ts",
        "vitest.config.mts"
      ],
      "vitest": false,
      "ignoreDependencies": [
        "cloudflare",
        "@vitest/coverage-istanbul",
        "@cloudflare/vitest-pool-workers"
      ]
    },
    "apps/backend/collector": {
      "entry": [
        "src/**/handler.ts",
        "src/index.ts",
        "lib/hellowork/scripts/*.ts",
        "lib/hellowork/**/__tests__/**/*.test.ts",
        "lib/hellowork/__tests__/fixtures.ts",
        "vitest.config.ts"
      ],
      "vitest": false,
      "ignoreDependencies": ["@vitest/coverage-v8", "tsx"]
    },
    "apps/backend/collector/infra": {
      "entry": [
        "bin/collector.ts",
        "lib/collector-stack.ts",
        "test/**/*.test.ts",
        "vitest.config.ts"
      ],
      "vitest": false,
      "ignoreDependencies": ["aws-cdk", "tsx", "@vitest/coverage-v8"]
    },
    "apps/frontend/hello-work-job-searcher": {
      "entry": [
        "src/app/**/page.tsx",
        "src/app/**/layout.tsx",
        "src/app/**/loading.tsx",
        "src/app/**/error.tsx",
        "src/app/**/not-found.tsx",
        "src/app/**/route.ts",
        "src/**/*.stories.{ts,tsx}",
        "src/**/*.test.{ts,tsx}",
        "src/lib/*.mock.ts",
        "next.config.{js,mjs,ts}",
        "vitest.config.ts",
        "instrumentation.ts"
      ],
      "vitest": false,
      "ignoreDependencies": [
        "react-dom",
        "@types/react-dom",
        "@vitest/browser",
        "playwright",
        "vitest"
      ]
    },
    "packages/db": {
      "entry": ["src/index.ts", "src/**/*.test.ts"],
      "ignoreDependencies": ["better-sqlite3", "kysely-codegen"]
    },
    "packages/models": {
      "entry": ["src/index.ts", "src/**/*.test.ts", "vitest.config.ts"],
      "vitest": false,
      "ignoreDependencies": ["@vitest/coverage-v8"]
    },
    "packages/logger": {
      "entry": ["src/index.ts", "src/**/*.test.ts"]
    }
  }
}
