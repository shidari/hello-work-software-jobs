{
	"name": "@sho/api",
	"version": "0.0.0",
	"private": true,
	"exports": {
		"./types": "./src/app/types.ts"
	},
	"scripts": {
		"deploy": "pnpm build && pnpm exec wrangler deploy",
		"no-main-deploy": "wrangler versions upload",
		"build": "tsdown",
		"dev": "pnpm exec wrangler d1 execute job-store --command=\"DROP TABLE IF EXISTS jobs; DROP TABLE IF EXISTS crawler_runs; DROP TABLE IF EXISTS job_detail_runs;\" && pnpm exec wrangler d1 execute job-store --file=../../../packages/db/schema.sql && pnpm exec wrangler dev",
		"start": "wrangler dev",
		"test": "vitest",
		"cf-typegen": "wrangler types",
		"type-check": "tsc --noEmit"
	},
	"devDependencies": {
		"@cloudflare/vitest-pool-workers": "^0.12.0",
		"@dotenvx/dotenvx": "^1.54.1",
		"@types/luxon": "^3.7.1",
		"@types/node": "^24.0.15",
		"tsdown": "^0.20.0",
		"tsx": "^4.20.3",
		"typescript": "^5.5.2",
		"vitest": "~4.0.0",
		"wrangler": "4.69.0"
	},
	"dependencies": {
		"@hono/standard-validator": "^0.2.0",
		"@hono/swagger-ui": "^0.6.0",
		"@sho/db": "workspace:*",
		"@sho/models": "workspace:*",
		"dotenv": "^17.0.0",
		"effect": "^3.16.5",
		"hono": "^4.11.9",
		"hono-openapi": "^1.0.8",
		"kysely": "^0.28.0",
		"luxon": "^3.7.2"
	}
}