{
  "lock": false,
  "fmt": {
    "lineWidth": 100,
    "indentWidth": 2,
    "semiColons": true,
    "useTabs": false
  },
  "compilerOptions": {
    "strict": true,
    "noImplicitAny": true,
    "noUnusedParameters": true,
    "noUnusedLocals": true,
    "noFallthroughCasesInSwitch": true
  },
  "tasks": {
    "check": "deno check ops-sandbox.ts ops-sandbox-image.ts",
    "fmt": "deno fmt ops-sandbox.ts ops-sandbox-image.ts"
  }
}
