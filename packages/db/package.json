{
	"name": "@sho/db",
	"version": "1.0.0",
	"private": true,
	"exports": {
		".": {
			"import": {
				"types": "./dist/index.d.mts",
				"default": "./dist/index.mjs"
			},
			"require": {
				"types": "./dist/index.d.cts",
				"default": "./dist/index.cjs"
			}
		}
	},
	"scripts": {
		"build": "pnpm exec tsdown",
		"type-check": "tsc --noEmit",
		"codegen": "rm -f local.db && sqlite3 local.db < schema.sql && kysely-codegen --dialect sqlite --url ./local.db --out-file src/generated/types.ts"
	},
	"dependencies": {
		"kysely": "^0.27.6",
		"kysely-d1": "^0.3.0"
	},
	"devDependencies": {
		"@cloudflare/workers-types": "^4.20250317.0",
		"@types/node": "^24.0.0",
		"better-sqlite3": "^11.9.1",
		"kysely-codegen": "^0.19.0",
		"tsdown": "^0.20.0",
		"typescript": "^5.8.3"
	}
}
